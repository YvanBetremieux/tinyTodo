{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "tinyTodo",
  "version": "0.1.0",
  "identifier": "com.tinytodo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "tinyTodo",
        "width": 400,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4ODcxMjM0OEU4Qzc0MzEKUldReGRJeU9OQktIK0hBRUFYQkM2OEdwUnNzU3pNaXNYVWw1Tmt2MHpiUHcrRkh2bkZLMjkzWW8K",
      "endpoints": [
        "https://github.com/YvanBetremieux/tinyTodo/releases/latest/download/latest.json"
      ]
    }
  }
}
